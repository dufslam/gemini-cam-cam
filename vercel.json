{
  "version": 2,
  "builds": [
    { "src": "config.js", "use": "@vercel/node" },
    { "src": "blend-image.js", "use": "@vercel/node" },
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "app.js", "use": "@vercel/static" },
    { "src": "style.css", "use": "@vercel/static" },
    { "src": "assets/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/config", "dest": "config.js" },
    { "src": "/api/blend-image", "dest": "blend-image.js" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
